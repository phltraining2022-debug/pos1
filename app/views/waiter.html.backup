<!-- Waiter/Staff Interface - Mobile Portrait -->
<div class="min-h-screen bg-gray-100 flex flex-col">
    <!-- Header -->
    <div class="bg-blue-600 text-white px-4 py-4 shadow-lg">
        <div class="flex items-center justify-between mb-3">
            <div>
                <h1 class="text-xl font-bold">Phục vụ</h1>
                <p class="text-sm opacity-90">{{currentUser.username}}</p>
            </div>
            <button ng-click="logout()" class="bg-red-500 hover:bg-red-600 px-4 py-2 rounded-lg text-sm font-semibold">
                <i class="fas fa-sign-out-alt mr-1"></i>Đăng xuất
            </button>
        </div>
        
        <!-- View Tabs -->
        <div class="grid grid-cols-4 gap-2">
            <button ng-click="switchView('rooms')" 
                    class="py-2 rounded-lg font-semibold transition-colors"
                    ng-class="view === 'rooms' ? 'bg-white text-blue-600' : 'bg-blue-500 text-white'">
                <i class="fas fa-door-open mr-1"></i>Phòng
            </button>
            <button ng-click="switchView('room-items')" 
                    ng-disabled="!selectedRoom"
                    class="py-2 rounded-lg font-semibold transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                    ng-class="view === 'room-items' ? 'bg-white text-blue-600' : 'bg-blue-500 text-white'">
                <i class="fas fa-plus mr-1"></i>Thêm món
            </button>
            <button ng-click="switchView('order')" 
                    ng-disabled="!selectedRoom"
                    class="py-2 rounded-lg font-semibold transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                    ng-class="view === 'order' ? 'bg-white text-blue-600' : 'bg-blue-500 text-white'">
                <i class="fas fa-utensils mr-1"></i>Xem đơn
            </button>
            <button ng-click="switchView('cleaning')" 
                    ng-disabled="!cleaningRoom"
                    class="py-2 rounded-lg font-semibold transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                    ng-class="view === 'cleaning' ? 'bg-white text-blue-600' : 'bg-blue-500 text-white'">
                <i class="fas fa-broom mr-1"></i>Dọn
            </button>
        </div>
    </div>
    
    <!-- Rooms View -->
    <div ng-if="view === 'rooms'" class="flex-1 overflow-y-auto p-4">
        <h2 class="text-lg font-bold text-gray-800 mb-4">Chọn phòng</h2>
        
        <div class="space-y-3">
            <div ng-repeat="room in rooms | filter:{status:'occupied'}" 
                 class="bg-white rounded-xl shadow-md p-4 border-l-4 border-red-500 hover:shadow-lg transition-shadow">
                <div class="flex items-center justify-between mb-2">
                    <div class="flex items-center space-x-3">
                        <i class="fas fa-music text-2xl text-red-500"></i>
                        <div>
                            <h3 class="font-bold text-lg text-gray-800">{{room.name}}</h3>
                            <p class="text-sm text-gray-600">{{room.type}} - {{room.capacity}} người</p>
                        </div>
                    </div>
                    <i class="fas fa-chevron-right text-gray-400"></i>
                </div>
                <div class="text-sm text-gray-600 mb-3">
                    <i class="fas fa-user mr-1"></i>
                    {{room.customerInfo.name || 'Khách lẻ'}}
                </div>
                <div class="flex space-x-2">
                    <button ng-click="selectRoomForView(room, 'room-items')" 
                            class="flex-1 bg-blue-500 hover:bg-blue-600 text-white py-2 px-3 rounded-lg text-sm font-semibold transition-colors">
                        <i class="fas fa-list mr-1"></i>Xem đơn
                    </button>
                    <button ng-click="selectRoomForView(room, 'order')" 
                            class="flex-1 bg-green-500 hover:bg-green-600 text-white py-2 px-3 rounded-lg text-sm font-semibold transition-colors">
                        <i class="fas fa-plus mr-1"></i>Thêm món
                    </button>
                </div>
            </div>
            
            <div ng-repeat="room in rooms | filter:{status:'cleaning'}" 
                 ng-click="selectRoomForCleaning(room)"
                 class="bg-white rounded-xl shadow-md p-4 border-l-4 border-yellow-500 cursor-pointer hover:shadow-lg transition-shadow">
                <div class="flex items-center justify-between">
                    <div class="flex items-center space-x-3">
                        <i class="fas fa-broom text-2xl text-yellow-500"></i>
                        <div>
                            <h3 class="font-bold text-lg text-gray-800">{{room.name}}</h3>
                            <p class="text-sm text-gray-600">Cần dọn dẹp</p>
                        </div>
                    </div>
                    <i class="fas fa-chevron-right text-gray-400"></i>
                </div>
            </div>
        </div>
        
        <div ng-if="(rooms | filter:{status:'occupied'}).length === 0 && (rooms | filter:{status:'cleaning'}).length === 0"
             class="text-center text-gray-400 py-12">
            <i class="fas fa-check-circle text-6xl mb-4 opacity-50"></i>
            <p class="text-lg">Không có công việc</p>
        </div>
    </div>
    
    <!-- Room Items View - Add items to order -->
    <div ng-if="view === 'room-items'" class="flex-1 flex flex-col">
        <div class="bg-white shadow px-4 py-3">
            <div class="flex items-center justify-between mb-3">
                <h2 class="text-lg font-bold text-gray-800">{{selectedRoom.name}} - Thêm món</h2>
                <button ng-click="switchView('order')" class="bg-green-500 text-white px-3 py-1 rounded text-sm">
                    <i class="fas fa-utensils mr-1"></i>Xem đơn
                </button>
            </div>
            
            <!-- Categories -->
            <div class="flex space-x-2 overflow-x-auto pb-2">
                <button ng-repeat="category in categories" 
                        ng-click="selectCategory(category)"
                        class="px-3 py-2 rounded-lg text-sm font-semibold whitespace-nowrap flex-shrink-0"
                        ng-class="selectedCategory.id === category.id ? 'bg-blue-600 text-white' : 'bg-gray-200 text-gray-700'">
                    <i ng-class="category.icon" class="mr-1"></i>{{category.name}}
                </button>
            </div>
        </div>
        
        <div class="flex-1 overflow-y-auto">
            <!-- Menu Items -->
            <div class="p-4">
                <div class="grid grid-cols-2 gap-4">
                    <div ng-repeat="item in menuItems" 
                         class="bg-white rounded-xl shadow-md p-4 border hover:shadow-lg transition-shadow">
                        <div class="flex items-center justify-between mb-3">
                            <div class="flex-1 min-w-0">
                                <h3 class="font-bold text-gray-800 mb-1">{{item.name}}</h3>
                                <div class="flex items-center justify-between">
                                    <span class="text-blue-600 font-bold">{{item.price | number:0}}đ</span>
                                    <span class="text-gray-500 text-sm">{{item.stock}} {{item.unit}}</span>
                                </div>
                            </div>
                            
                            <button ng-click="addToCart(item)" 
                                    class="bg-blue-600 hover:bg-blue-700 text-white w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0">
                                <i class="fas fa-plus"></i>
                            </button>
                        </div>
                        
                        <div ng-if="item.description" class="text-sm text-gray-600 mb-2">
                            {{item.description}}
                        </div>
                        
                        <div ng-if="item.alcoholic" class="text-xs text-red-600 font-semibold">
                            <i class="fas fa-wine-bottle mr-1"></i>Rượu
                        </div>
                    </div>
                </div>
            </div>
        </div>
                                    <span class="mx-2">•</span>
                                    <span>{{item.unitPrice | number:0}}đ</span>
                                    <span ng-if="item.note" class="ml-2 text-orange-600">• {{item.note}}</span>
                                </div>
                            </div>
                            <div class="text-right">
                                <div class="font-bold text-green-600">{{item.subtotal | number:0}}đ</div>
                                <div class="text-xs text-gray-500">{{item.status || 'Đã gửi'}}</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- No items -->
            <div ng-if="cart.length === 0 && sentItems.length === 0" class="text-center text-gray-400 py-12">
                <i class="fas fa-receipt text-6xl mb-4 opacity-50"></i>
                <p class="text-lg">Chưa có đơn hàng nào trong phòng này</p>
            </div>
        </div>
    </div>
    
    <!-- Order View -->
    <div ng-if="view === 'order'" class="flex-1 flex flex-col">
        <div class="bg-white shadow px-4 py-3">
            <div class="flex items-center justify-between mb-3">
                <h2 class="text-lg font-bold text-gray-800">{{selectedRoom.name}}</h2>
                <span class="bg-red-500 text-white px-3 py-1 rounded-full text-sm font-semibold">
                    {{cart.length}} món
                </span>
            </div>
            
            <!-- Categories -->
            <div class="flex space-x-2 overflow-x-auto no-scrollbar">
                <button ng-repeat="category in categories" 
                        ng-click="selectCategory(category)"
                        class="px-4 py-2 rounded-full font-semibold whitespace-nowrap transition-colors"
                        ng-class="selectedCategory.id === category.id ? 'bg-blue-600 text-white' : 'bg-gray-100 text-gray-700'">
                    <i class="fas {{category.icon}} mr-1"></i>{{category.name}}
                </button>
            </div>
        </div>
        
        <!-- Menu Items -->
        <div class="flex-1 overflow-y-auto p-4">
            <div class="grid grid-cols-2 gap-4">
                <div ng-repeat="item in menuItems" 
                     class="bg-white rounded-xl shadow-md p-4 border hover:shadow-lg transition-shadow">
                    <div class="flex items-center justify-between mb-3">
                        <div class="flex-1 min-w-0">
                            <h3 class="font-bold text-gray-800 mb-1">{{item.name}}</h3>
                            <div class="flex items-center justify-between">
                                <span class="text-blue-600 font-bold">{{item.price | number:0}}đ</span>
                                <span class="text-gray-500 text-sm">{{item.stock}} {{item.unit}}</span>
                            </div>
                        </div>
                        
                        <button ng-click="addToCart(item)" 
                                class="bg-blue-600 hover:bg-blue-700 text-white w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0">
                            <i class="fas fa-plus"></i>
                        </button>
                    </div>
                    
                    <div ng-if="item.description" class="text-sm text-gray-600 mb-2">
                        {{item.description}}
                    </div>
                    
                    <div ng-if="item.alcoholic" class="text-xs text-red-600 font-semibold">
                        <i class="fas fa-wine-bottle mr-1"></i>Rượu
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Cart Footer -->
        <div ng-if="cart.length > 0" class="fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 p-4 shadow-lg">
            <div class="max-h-40 overflow-y-auto mb-3">
                <div ng-repeat="item in cart" class="flex items-center justify-between mb-2 p-2 bg-gray-50 rounded-lg">
                    <div class="flex-1">
                        <div class="flex items-center justify-between">
                            <span class="font-semibold text-gray-800">{{item.name}}</span>
                            <button ng-click="editItemNote(item)" 
                                    class="text-blue-600 hover:text-blue-800 ml-2">
                                <i class="fas fa-edit text-sm"></i>
                            </button>
                        </div>
                        <div ng-if="item.note" class="text-sm text-gray-600 mt-1 italic">
                            "{{item.note}}"
                        </div>
                        <div class="flex items-center space-x-2 mt-1">
                            <button ng-click="updateQuantity(item, -1)" class="bg-gray-200 text-gray-800 w-6 h-6 rounded text-sm">
                                <i class="fas fa-minus"></i>
                            </button>
                            <span class="font-bold">{{item.quantity}}</span>
                            <button ng-click="updateQuantity(item, 1)" class="bg-gray-200 text-gray-800 w-6 h-6 rounded text-sm">
                                <i class="fas fa-plus"></i>
                            </button>
                        </div>
                    </div>
                    <span class="text-blue-600 font-bold ml-2">{{item.price * item.quantity | number:0}}đ</span>
                </div>
            </div>
            
            <div class="flex space-x-3">
                <button ng-click="switchView('order')" class="flex-1 bg-green-500 hover:bg-green-600 text-white py-3 rounded-lg font-semibold">
                    <i class="fas fa-utensils mr-2"></i>Xem đơn
                </button>
                <button ng-click="sendOrder()" class="flex-1 bg-blue-600 hover:bg-blue-700 text-white py-3 rounded-lg font-semibold">
                    <i class="fas fa-paper-plane mr-2"></i>Gửi bếp
                </button>
            </div>
        </div>
    </div>
    
    <!-- Order View - View current order -->
    <div ng-if="view === 'order'" class="flex-1 flex flex-col">
        <div class="bg-white shadow px-4 py-3">
            <div class="flex items-center justify-between mb-3">
                <h2 class="text-lg font-bold text-gray-800">{{selectedRoom.name}} - Đơn hàng hiện tại</h2>
                <button ng-click="refreshRoomItems()" class="bg-blue-500 text-white px-3 py-1 rounded text-sm">
                    <i class="fas fa-sync-alt mr-1"></i>Làm mới
                </button>
            </div>
        </div>
        
        <div class="flex-1 overflow-y-auto p-4">
            <!-- Current Cart Items -->
            <div ng-if="cart.length > 0" class="mb-6">
                <h3 class="text-md font-bold text-gray-700 mb-3 flex items-center">
                    <i class="fas fa-shopping-cart text-blue-500 mr-2"></i>
                    Giỏ hàng hiện tại ({{cart.length}} món)
                </h3>
                <div class="space-y-2">
                    <div ng-repeat="item in cart" class="bg-blue-50 border border-blue-200 rounded-lg p-3">
                        <div class="flex items-center justify-between">
                            <div class="flex-1">
                                <div class="font-semibold text-gray-800">{{item.name}}</div>
                                <div class="text-sm text-gray-600">
                                    <span class="font-medium">{{item.quantity}} {{item.unit}}</span>
                                    <span class="mx-2">•</span>
                                    <span>{{item.price | number:0}}đ</span>
                                    <span ng-if="item.note" class="ml-2 text-orange-600">• {{item.note}}</span>
                                </div>
                            </div>
                            <div class="text-right">
                                <div class="font-bold text-blue-600">{{item.price * item.quantity | number:0}}đ</div>
                                <div class="text-xs text-gray-500">Chưa gửi</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Sent Items -->
            <div ng-if="sentItems.length > 0" class="mb-6">
                <h3 class="text-md font-bold text-gray-700 mb-3 flex items-center">
                    <i class="fas fa-paper-plane text-green-500 mr-2"></i>
                    Đã gửi bếp ({{sentItems.length}} món)
                </h3>
                <div class="space-y-2">
                    <div ng-repeat="item in sentItems" class="bg-green-50 border border-green-200 rounded-lg p-3">
                        <div class="flex items-center justify-between">
                            <div class="flex-1">
                                <div class="font-semibold text-gray-800">{{item.name}}</div>
                                <div class="text-sm text-gray-600">
                                    <span class="font-medium">{{item.quantity}} {{item.unit}}</span>
                                    <span class="mx-2">•</span>
                                    <span>{{item.price | number:0}}đ</span>
                                    <span ng-if="item.note" class="ml-2 text-orange-600">• {{item.note}}</span>
                                </div>
                            </div>
                            <div class="text-right">
                                <div class="font-bold text-green-600">{{item.price * item.quantity | number:0}}đ</div>
                                <div class="text-xs text-gray-500">Đã gửi {{item.sentAt | date:'HH:mm'}}</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- No items message -->
            <div ng-if="cart.length === 0 && sentItems.length === 0" class="text-center py-12">
                <i class="fas fa-utensils text-6xl text-gray-300 mb-4"></i>
                <h3 class="text-lg font-semibold text-gray-600 mb-2">Chưa có đơn hàng</h3>
                <p class="text-gray-500">Chọn "Thêm món" để tạo đơn hàng mới</p>
            </div>
        </div>
        
        <!-- Order Actions -->
        <div ng-if="cart.length > 0" class="fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 p-4 shadow-lg">
            <div class="flex space-x-3">
                <button ng-click="switchView('room-items')" class="flex-1 bg-blue-500 hover:bg-blue-600 text-white py-3 rounded-lg font-semibold">
                    <i class="fas fa-plus mr-2"></i>Thêm món
                </button>
                <button ng-click="sendOrder()" class="flex-1 bg-green-600 hover:bg-green-700 text-white py-3 rounded-lg font-semibold">
                    <i class="fas fa-paper-plane mr-2"></i>Gửi bếp
                </button>
            </div>
        </div>
    </div>
    
    <!-- Edit Note Modal -->
    <div id="editNoteModal" class="fixed inset-0 bg-black bg-opacity-50 hidden z-50 flex items-center justify-center p-4">
        <div class="bg-white rounded-xl shadow-xl max-w-md w-full">
            <div class="p-6">
                <h3 class="text-lg font-bold text-gray-800 mb-4">Ghi chú cho món</h3>
                <p class="text-gray-600 mb-4">{{editingItem.name}}</p>
                
                <textarea ng-model="editingItem.note" 
                         placeholder="Nhập ghi chú cho món này..."
                         class="w-full border border-gray-300 rounded-lg p-3 focus:outline-none focus:ring-2 focus:ring-blue-500"
                         rows="3"></textarea>
                
                <div class="flex space-x-3 mt-6">
                    <button ng-click="saveItemNote()" 
                            class="flex-1 bg-blue-600 hover:bg-blue-700 text-white py-3 rounded-lg font-semibold">
                        Lưu
                    </button>
                    <button ng-click="cancelEditNote()" 
                            class="flex-1 bg-gray-300 hover:bg-gray-400 text-gray-800 py-3 rounded-lg font-semibold">
                        Hủy
                    </button>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Cleaning View -->
    <div ng-if="view === 'cleaning'" class="flex-1 flex flex-col">
        <div class="bg-white shadow px-4 py-3">
            <h2 class="text-lg font-bold text-gray-800">Dọn phòng: {{cleaningRoom.name}}</h2>
            <p class="text-sm text-gray-600">Hoàn thành tất cả các mục kiểm tra</p>
        </div>
        
        <div class="flex-1 overflow-y-auto p-4">
            <div class="space-y-3 mb-20">
                <div ng-repeat="item in checklist.items" 
                     ng-click="toggleChecklistItem(item)"
                     class="bg-white rounded-xl shadow-md p-4 cursor-pointer transition-all"
                     ng-class="item.checked ? 'border-2 border-green-500' : 'border-2 border-gray-200'">
                    <div class="flex items-center space-x-3">
                        <div class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0"
                             ng-class="item.checked ? 'bg-green-500 text-white' : 'bg-gray-200 text-gray-400'">
                            <i class="fas" ng-class="item.checked ? 'fa-check' : 'fa-circle'"></i>
                        </div>
                        <span class="font-semibold text-gray-800 flex-1" 
                              ng-class="item.checked ? 'line-through text-gray-400' : ''">
                            {{item.name}}
                        </span>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Complete Button -->
        <div class="fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 p-4 shadow-lg">
            <button ng-click="completeCleaning()" 
                    class="w-full bg-green-600 hover:bg-green-700 text-white py-4 rounded-xl font-bold text-lg">
                <i class="fas fa-check-circle mr-2"></i>Hoàn tất dọn phòng
            </button>
        </div>
    </div>
</div>
