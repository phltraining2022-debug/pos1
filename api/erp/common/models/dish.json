			"required": true,
			"unique": true
		},
		"name": {
			"type": "string",
			"required": true
		},
		"category": {
			"type": "string"
		},
		"type": {
			"type": "string"
		},
		"components": {
			"type": "array",
			"items": {
				"type": "object",
