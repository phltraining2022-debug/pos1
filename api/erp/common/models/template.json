{
	"name": "Template",
	"plural": "Templates",
	"base": "AppModel",
	"idInjection": true,
	"options": {
		"validateUpsert": true
	},
	"properties": {
		"name": {
			"type": "string",
			"required": true
		},
		"content": {
			"type": "string"
		},
		"isPublished": {
			"type": "boolean"
		},
		"header": {
			"type": "string"
		},
		"footer": {
			"type": "string"
		},
		"subject": {
			"type": "string"
		},
		"baseId": {
			"type": "string"
		},
		"category": {
			"type": "string"
		},
		"css": {
			"type": "string"
		},
		"dataBlocks": {
			"type": "array"
		},
		"printOptions": {
			"type": "object"
		},
		"slug": {
			"type": "string"
		}
	},
	"validations": [],
	"scope": {
		"include": [
			{
				"relation": "blocks",
				"scope": {
					"order": "order DESC"
				}
			},
			{
				"relation": "templateBlocks",
				"scope": {
					"order": "order DESC"
				}
			},
			"company"
		]
	},
	"relations": {
		"base": {
			"type": "belongsTo",
			"model": "Template",
			"foreignKey": "baseId",
			"optional": true
		},
		"blocks": {
			"type": "hasMany",
			"model": "Block",
			"through": "TemplateBlock",
			"foreignKey": "templateId",
			"keyThrough": "blockId"
		},
		"templateBlocks": {
			"type": "hasMany",
			"model": "TemplateBlock",
			"foreignKey": "templateId"
		},
		"refBlocks": {
			"type": "referencesMany",
			"model": "Block",
			"foreignKey": "refBlockIds"
      	},
		"company": {
			"type": "belongsTo",
			"model": "clinic",
			"foreignKey": "clinicId"
      	}
	},
	"url": "`/${slug}`",
	"acls": [],
	"methods": {}
}