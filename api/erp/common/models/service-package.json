  },
  "properties": {
    "name": {
      "type": "string",
      "required": true
    },
    "fromDate": {
      "type": "date"
    },
    "endDate": {
      "type": "date"
    },
    "price": {
      "type": "number",
      "required": true
    },
    "content": {
      "type": "string"
    },
    "services": {
      "type": [
        "string"
      ],
