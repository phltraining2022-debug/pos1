		},
		"acceptanceDeadline": {
			"type": "date"
		},
		"status": {
			"type": "string",
			"enum": [
				"Lead",
				"Preparation",
				"App Submitted",
				"Conditional Offer",
				"Full Offer",
				"Payment",
				"Visa App",
				"Visa Grant",
