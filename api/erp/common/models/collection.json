{
	"name": "Collection",
	"plural": "Collections",
	"base": "AppModel",
	"idInjection": true,
	"options": {
		"validateUpsert": true
	},
	"properties": {
		"name": {
			"type": "string",
			"required": true
		},
		"description": {
			"type": "string"
		},
		"image": {
			"type": "string"
		},
		"banner": {
			"type": "string"
		}
	},
	"relations": {
		"products": {
			"type": "referencesMany",
			"model": "Product",
			"foreignKey": "productIds"
		}
	}
}