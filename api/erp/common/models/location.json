      "type": "string",
      "required": true
    },
    "isPublished": {
			"type": "boolean"
		},
    "id": {
      "type": "number",
      "id": true
    },
    "codeId": {
      "type": "string"
    },
    "rankingCountry": {
      "type": "string"
    },
    "rankedUniversities": {
      "type": "string"
    },
    "international": {
      "type": "string"
    },
    "vietnameseStudent": {
      "type": "string"
    },
    "isSearchable": {
      "type": "string"
    },
    "isActive": {
      "type": "string"
    },
    "showAsScholarship": {
      "type": "string"
    },
    "orderLocation": {
      "type": "string"
    },
    "slug": {
      "type": "string"
    },
    "logo": {
      "type": "string"
    },
    "whyChoose": {
      "type": "string"
    }
  },
  "validations": [],
