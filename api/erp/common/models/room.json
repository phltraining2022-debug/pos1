		"validateUpsert": true
	},
	"properties": {
		"name": {
			"type": "string",
			"required": true
		},
		"code": {
			"type": "string"
		},
		"branchId": {
			"type": "number"
		},
		"capacity": {
			"type": "number"
		},
		"floor": {
