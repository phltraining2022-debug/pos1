map $subdomain $port {
    default 20000; 
    amor 10001;
}


server {
    listen 443 ssl http2;

    server_name ~^(?<subdomain>.+).test.live1.vn;

       ssl_certificate  /etc/letsencrypt/live/test.live1.vn/fullchain.pem;
       ssl_certificate_key  /etc/letsencrypt/live/test.live1.vn/privkey.pem;

       root /var/www/erp;


       # 2. Thêm resolver để Nginx phân giải tên miền khi dùng biến trong proxy_pass
       resolver 8.8.8.8 1.1.1.1 valid=30s;

  
    location = /xad_/ {
        set $proxy_target 'https://cdn.live1.vn/xadmin-kara.html';
        proxy_pass $proxy_target;
        proxy_set_header  X-Real-IP $remote_addr;
        proxy_set_header  X-Forwarded-Proto https;
        proxy_set_header  X-Forwarded-For $remote_addr;
        proxy_set_header  X-Forwarded-Host $remote_addr;
    }

    location ^~ /xad2_/ {
        proxy_pass https://cdn.live1.vn/builder-1/xad/;
        proxy_set_header Host cdn.live1.vn;
        proxy_set_header  X-Real-IP $remote_addr;
        proxy_set_header  X-Forwarded-Proto https;
        proxy_set_header  X-Forwarded-For $remote_addr;
        proxy_set_header  X-Forwarded-Host $host;
    }

    location = /mad_/ {
        proxy_pass https://cdn.live1.vn/mobile-erp/;

        proxy_intercept_errors on;
        
        error_page 404 = /mad_/index.html;

        # 3. Sửa lại các header
        proxy_set_header Host cdn.live1.vn; # Báo cho CDN biết bạn muốn truy cập host nào
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host; # Giữ nguyên host gốc mà người dùng truy cập
    }
 
 
    location ^~ /api/ {
        proxy_pass http://127.0.0.1:20000;
        proxy_set_header  Host $host;
        proxy_set_header  X-Real-IP $remote_addr;
        proxy_set_header  X-Forwarded-Proto https;
        proxy_set_header  X-Forwarded-For $remote_addr;
        proxy_set_header  X-Forwarded-Host $remote_addr;
    }
    
    location ^~ /xa_/ {
        alias /var/www/erp/;
        break;
    }

    location ^~ /static/ { 
        alias /home/ubuntu/ats/api/storage/static/;
        break;
    }

    location = / {
        set $proxy_target 'http://127.0.0.1:$port/api/pdf?html=true&template=home&modelName=clinic&filter={"where":{}}';
        proxy_pass $proxy_target;
        proxy_set_header  Host $host;
        proxy_set_header  X-Real-IP $remote_addr;
        proxy_set_header  X-Forwarded-Proto https;
        proxy_set_header  X-Forwarded-For $remote_addr;
        proxy_set_header  X-Forwarded-Host $remote_addr;
        proxy_set_header  from-public-site $host;
    }

    location = /robots.txt {
        add_header Content-Type text/plain;
        return 200 "User-agent: *\nDisallow: /\n";
    }


    location ~ ^/(?<model>[^/]+)/?$ {     
        set $custom_query_string $args;

        # Construct the proxy target with the query string included
        set $proxy_target 'http://127.0.0.1:$port/api/pdf?html=true&template=$model&modelName=$model&filter={"where":{}}';
        if ($custom_query_string) {
            set $proxy_target 'http://127.0.0.1:$port/api/pdf?html=true&template=$model&modelName=$model&filter={"where":{}}&$custom_query_string';
        }

        proxy_pass $proxy_target;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header from-public-site $host;

        # Capture the original URL with the query string
        set $originalUrl $request_uri;

        # Set the custom header with the original URL
        proxy_set_header originalUrl $originalUrl;
        proxy_set_header original-url $request_uri;
    }

    location ~ ^/ecommerce/(?<category>[^/]+)/(?<subcategory>[^/]+)/?$ { 
        set $custom_query_string $args;

        # Construct the proxy target with the query string included
        set $proxy_target 'http://127.0.0.1:$port/api/pdf?html=true&template=$category&modelName=$subcategory&filter={"where":{}}';
        if ($custom_query_string) {
            set $proxy_target 'http://127.0.0.1:$port/api/pdf?html=true&template=$category&modelName=$subcategory&filter={"where":{}}&$custom_query_string';
        }
        
        proxy_pass $proxy_target; 
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header from-public-site $host;

        # Capture the original URL with the query string
        set $originalUrl $request_uri;

        # Set the custom header with the original URL
        proxy_set_header X-Category $category;
        proxy_set_header X-Subcategory $subcategory;
        proxy_set_header original-url $request_uri;
    }


    location ~ ^/ecommerce/(?<category>[^/]+)/(?<subcategory>[^/]+)/(?<ptype>[^/]+)/?$ {
        set $custom_query_string $args;

        # Construct the proxy target with the query string included
        set $proxy_target 'http://127.0.0.1:$port/api/pdf?html=true&template=$category&modelName=$subcategory&filter={"where":{}}';
        if ($custom_query_string) {
            set $proxy_target 'http://127.0.0.1:$port/api/pdf?html=true&template=$category&modelName=$subcategory&filter={"where":{}}&$custom_query_string';
        }

        proxy_pass $proxy_target;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header from-public-site $host;

        # Capture the original URL with the query string
        set $originalUrl $request_uri;

        # Set the custom header with the original URL
        proxy_set_header X-Category $category;
        proxy_set_header X-Subcategory $subcategory;
        proxy_set_header X-Type $ptype;
        proxy_set_header original-url $request_uri;
    }

    location ~ ^/news/(?<category>[^/]+)/?$ {
        set $custom_query_string $args;

        set $proxy_target 'http://127.0.0.1:$port/api/pdf?html=true&template=news-category&modelName=news&filter={"where":{"category":"$category"}}';
        if ($custom_query_string) {
            set $proxy_target 'http://127.0.0.1:$port/api/pdf?html=true&template=news-category&modelName=news&filter={"where":{"category":"$category"}}&$custom_query_string';
        }

        proxy_pass $proxy_target;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header from-public-site $host;

        # Capture the original URL with the query string
        set $originalUrl $request_uri;

        # Set the custom header with the original URL
        proxy_set_header X-Category $category;
        proxy_set_header original-url $request_uri;
    }


    location ~ ^/ecommerce/(?<category>[^/]+)/?$ {
        set $custom_query_string $args;

        set $proxy_target 'http://127.0.0.1:$port/api/pdf?html=true&template=$category&modelName=$category&filter={"where":{}}';
        if ($custom_query_string) {
            set $proxy_target 'http://127.0.0.1:$port/api/pdf?html=true&template=$category&modelName=$category&filter={"where":{}}&$custom_query_string';
        }

        proxy_pass $proxy_target;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header from-public-site $host;

        # Capture the original URL with the query string
        set $originalUrl $request_uri;

        # Set the custom header with the original URL
        proxy_set_header X-Category $category;
        proxy_set_header original-url $request_uri;
    }


    # Thêm ^~ để ưu tiên block này hơn regex
    location ^~ /student-api/ {
        #proxy_pass https://ats.prod.live1.vn/api/;
        proxy_set_header  Host $host;
        proxy_set_header  X-Real-IP $remote_addr;
        proxy_set_header  X-Forwarded-Proto https;
        proxy_set_header  X-Forwarded-For $remote_addr;
        proxy_set_header  X-Forwarded-Host $remote_addr;
        proxy_set_header  from-public-site $host;
    }

    location ~ ^/(?<model>[^/]+)/(?<item_name>[^/]+)$ {  
        set $custom_query_string $args;
        set $proxy_target 'http://127.0.0.1:$port/api/pdf?html=true&template=$model-detail&modelName=$model&item=$item_name&filter={"where":{"or":[{"slug":"$item_name"},{"id":"$item_name"}]}}&$custom_query_string';
        proxy_pass $proxy_target;
        proxy_set_header  Host $host;
        proxy_set_header  from-public-site $host;
        proxy_set_header  X-Real-IP $remote_addr;
        proxy_set_header  X-Forwarded-Proto https;
        proxy_set_header  X-Forwarded-For $remote_addr;
        proxy_set_header  X-Forwarded-Host $remote_addr;
    }


    location ~ ^/en/(?<model>[^/]+)/(?<item_name>[^/]+)$ {
        set $custom_query_string $args;
        set $proxy_target 'http://127.0.0.1:$port/api/pdf?html=true&template=$model-detail&modelName=$model&item=$item_name&filter={"where":{"or":[{"slug":"$item_name"},{"id":"$item_name"}]}}&$custom_query_string';
        proxy_pass $proxy_target;
        proxy_set_header  Host $host;
        proxy_set_header  from-public-site $host;
        proxy_set_header  X-Real-IP $remote_addr;
        proxy_set_header  X-Forwarded-Proto https;
        proxy_set_header  X-Forwarded-For $remote_addr;
        proxy_set_header  X-Forwarded-Host $remote_addr;
    } 

}

server {
    server_name ~^(?<subdomain>.+).test.live1.vn;
    return 301 https://$host$request_uri;
    listen 80;
}
