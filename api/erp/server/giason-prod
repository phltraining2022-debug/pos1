        proxy_set_header original-url $request_uri;

     }


     location /student-api/ {
        #proxy_pass https://ats.prod.live1.vn/api/;
        proxy_set_header  Host $host;
        proxy_set_header  X-Real-IP $remote_addr;
        proxy_set_header  X-Forwarded-Proto https;
        proxy_set_header  X-Forwarded-For $remote_addr;
        proxy_set_header  X-Forwarded-Host $remote_addr;
        proxy_set_header  from-public-site $host;
     }

    location ~ "^/(?<base_name_path>.*)\-(?<serialNo>[A-Z0-9]{6,18})$" {
    set $custom_query_string $args;

    set $proxy_target 'http://127.0.0.1:20002/api/pdf?html=true&template=Product-detail&modelName=Product&filter={"where":{"or":[{"serialNo":"$serialNo"},{"id":"$serialNo"}]}}';
    proxy_pass $proxy_target;
    proxy_set_header Host $host;
    proxy_set_header from-public-site $host; # Your custom header
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-Proto $scheme; # Use $scheme for http/https
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for; # Appends to existing X-Forwarded-For
    proxy_set_header X-Forwarded-Host $host; # Original host requested by client
}



     location ~ ^/(?<model>[^/]+)/(?<item_name>[^/]+)$ {  
        set $custom_query_string $args;
        set $proxy_target 'http://127.0.0.1:20002/api/pdf?html=true&template=$model-detail&modelName=$model&item=$item_name&filter={"where":{"or":[{"slug":"$item_name"},{"id":"$item_name"}]}}&$custom_query_string';
        proxy_pass $proxy_target;
        set $originalUrl $request_uri;
        proxy_set_header  Host $host;
        proxy_set_header original-url $request_uri;
	proxy_set_header  from-public-site $host;
        proxy_set_header  X-Real-IP $remote_addr;
        proxy_set_header  X-Forwarded-Proto https;
        proxy_set_header  X-Forwarded-For $remote_addr;
        proxy_set_header  X-Forwarded-Host $remote_addr;
        proxy_set_header X-Category $model;
        proxy_set_header X-Subcategory $item_name;     

}


location ~ ^/en/(?<model>[^/]+)/(?<item_name>[^/]+)$ {
        set $custom_query_string $args;
        set $proxy_target 'http://127.0.0.1:20002/api/pdf?html=true&template=$model-detail&modelName=$model&item=$item_name&filter={"where":{"or":[{"slug":"$item_name"},{"id":"$item_name"}]}}&$custom_query_string';
