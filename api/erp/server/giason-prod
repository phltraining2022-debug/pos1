        if ($custom_query_string) {
            set $proxy_target 'http://127.0.0.1:20002/api/pdf?html=true&template=$category&modelName=$category&filter={"where":{}}&$custom_query_string';
        }



        proxy_pass $proxy_target;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header from-public-site $host;

         # Capture the original URL with the query string
        set $originalUrl $request_uri;

        # Set the custom header with the original URL
