{
  "expo": {
    "name": "Kara POS",
    "slug": "kara-pos-mobile",
    "scheme": "kara-pos-mobile",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "platforms": [
      "ios",
      "android"
    ],
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#7c3aed"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "vn.vvs.pos1",
      "buildNumber": "1",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Dùng camera để quét mã QR đặt món và thanh toán.",
        "NSPhotoLibraryUsageDescription": "Dùng để lưu và tải ảnh sản phẩm.",
        "NSFaceIDUsageDescription": "Dùng Face ID để đăng nhập nhanh.",
        "NSUserNotificationsUsageDescription": "Nhận thông báo đơn hàng mới và cập nhật từ hệ thống.",
        "ITSAppUsesNonExemptEncryption": false,
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false,
          "NSExceptionDomains": {
            "kara.test.live1.vn": {
              "NSExceptionAllowsInsecureHTTPLoads": false,
              "NSExceptionMinimumTLSVersion": "TLSv1.2",
              "NSIncludesSubdomains": true
            }
          }
        }
      }
    },
    "android": {
      "package": "vn.vvs.pos1",
      "versionCode": 1,
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "INTERNET"
      ]
    },
    "plugins": [
      "expo-asset",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#7c3aed",
          "sounds": []
        }
      ]
    ],
    "extra": {
      "sku": "pos1",
      "appleId": "6761367793",
      "eas": {
        "projectId": "69e58ae1-6906-4289-8e64-903a60afb121"
      }
    }
  }
}
